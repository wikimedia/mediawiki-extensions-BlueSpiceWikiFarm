				"DBLoadBalancer",
				"TitleFactory",
				"ContentLanguage",
				"NamespaceInfo",
				"PageProps",
				"BlueSpiceWikiFarm.GlobalDatabaseQuery"
			]
		},
		{
			"path": "/bluespice/farm/v1/template-query-store",
			"class": "BlueSpice\\WikiFarm\\TitleSearch\\Rest\\FarmTemplateQueryStore",
			"services": [
				"HookContainer",
				"DBLoadBalancer",
				"TitleFactory",
				"ContentLanguage",
				"NamespaceInfo",
				"PageProps",
				"BlueSpiceWikiFarm.GlobalDatabaseQuery",
				"BlueSpiceWikiFarm.InstanceStore",
				"BlueSpiceWikiFarm._Config"
			]
		},
		{
			"method": "POST",
			"path": "/bluespice/farm/v1/access/assign",
			"class": "BlueSpice\\WikiFarm\\Rest\\AssignRoleToEntityHandler",
			"services": [
				"PermissionManager", "BlueSpiceWikiFarm.GroupRoleManager", "UserFactory",
				"UserGroupManager", "BlueSpiceWikiFarm.InstanceGroupCreator", "BlueSpiceWikiFarm.InstanceStore"
			]
		},
		{
			"path": "/bluespice/farm/v1/access/assignments",
			"class": "BlueSpice\\WikiFarm\\Rest\\AccessAssignmentsStore",
			"services": [
				"HookContainer", "PermissionManager", "BlueSpiceWikiFarm.InstanceGroupCreator",
				"DBLoadBalancer", "BlueSpiceWikiFarm.GroupRoleManager", "BlueSpiceWikiFarm.InstanceStore"
			]
		},
		{
			"path": "/bluespice/farm/v1/access/accessible",
