		},
		{
			"method": "GET",
			"path": "/bluespice/farm/v1/process/{processId}",
			"class": "\\BlueSpice\\WikiFarm\\Rest\\ProcessHandler",
			"services": [ "ProcessManager" ]
		},
		{
			"path": "/bluespice/farm/v1/limits",
			"class": "\\BlueSpice\\WikiFarm\\Rest\\LimitsHandler",
			"services": [ "PermissionManager", "BlueSpiceWikiFarm._InstanceCountLimiter" ]
		},
