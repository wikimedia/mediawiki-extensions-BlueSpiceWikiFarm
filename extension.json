		"APIAfterExecute": "handleSharedResources",
		"MWStakeCommonUIRegisterSkinSlotComponents": "common-user-interface",
		"GetPreferences": "userpreference",
		"ContentStabilizationGetCurrentInclusions": "handleSharedStabilization",
		"ContentStabilizationFetchForeignRevisionForTransclusion": "handleSharedStabilization",
		"ContentStabilizationGetStableForeignInclusion": "handleSharedStabilization",
		"MWStakeMCPGetWikiMap": "populateWikiMap",
		"BeforeInitialize": "redirectUserPage",
		"SpecialPageBeforeExecute": "addGlobalUnifiedTaskOverviewModule",
		"BSUserManagerBeforeAddGroup": "addGroupPrefix",
		"MediaWikiServices": "configureContentTransfer",
		"MWStakeGroupStoreGroupTypeFilter": "handleGroupStore",
		"MWStakeGroupStoreGroupDisplayName": "handleGroupStore"
