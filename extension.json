	"HookHandlers": {
		"runDatabaseUpdates": {
			"class": "BlueSpice\\WikiFarm\\Hook\\RunDatabaseUpdates"
		},
		"handleTag": {
			"class": "BlueSpice\\WikiFarm\\Hook\\HandleTag"
		},
		"handleInterwiki": {
			"class": "BlueSpice\\WikiFarm\\Hook\\HandleInterwiki",
			"services": [ "BlueSpiceWikiFarm._Config" ]
		},
		"addSearchInstanceContext": {
			"class": "BlueSpice\\WikiFarm\\Hook\\Integration\\AddSearchInstanceContext",
			"services": [ "BlueSpiceWikiFarm._GlobalSearchDataProvider" ]
		},
		"addSpecialPages": {
			"class": "BlueSpice\\WikiFarm\\Hook\\AddSpecialPages",
			"services": [ "BlueSpiceWikiFarm._Config" ]
		},
		"setupGroupMessages": {
			"class": "BlueSpice\\WikiFarm\\Hook\\SetupGroupMessages",
			"services": [ "BlueSpiceWikiFarm._Config" ]
		},
		"addBootstrap": {
			"class": "BlueSpice\\WikiFarm\\Hook\\AddBootstrap",
			"services": [ "BlueSpiceWikiFarm.InstanceStore", "BlueSpiceWikiFarm._Config" ]
		},
		"handleSharedResources": {
			"class": "BlueSpice\\WikiFarm\\Hook\\HandleSharedResources",
			"services": [
				"BlueSpiceWikiFarm._Config", "MainConfig", "TitleFactory",
				"BlueSpiceWikiFarm.GlobalDatabaseQuery", "BlueSpiceWikiFarm.InstanceStore",
				"BlueSpiceWikiFarm.AccessControlStore", "BlueSpiceWikiFarm.ForeignRequestExecution",
				"NamespaceInfo"
			]
		},
		"handleSharedStabilization": {
			"class": "BlueSpice\\WikiFarm\\Hook\\HandleSharedStabilization",
			"services": [
				"BlueSpiceWikiFarm._Config", "MainConfig", "TitleFactory",
				"BlueSpiceWikiFarm.GlobalDatabaseQuery", "BlueSpiceWikiFarm.InstanceStore",
				"BlueSpiceWikiFarm.AccessControlStore", "BlueSpiceWikiFarm.ForeignRequestExecution",
				"NamespaceInfo"
			]
		},
		"common-user-interface": {
			"class": "BlueSpice\\WikiFarm\\Hook\\CommonUserInterface",
			"services": [ "BlueSpiceWikiFarm.InstanceStore", "BlueSpiceWikiFarm._Config",
				"UserOptionsLookup", "BlueSpiceWikiFarm.AccessControlStore" ]
		},
		"userpreference": {
			"class": "BlueSpice\\WikiFarm\\Hook\\AddUserPreference"
		},
		"populateWikiMap": {
			"class": "BlueSpice\\WikiFarm\\Hook\\PopulateWikiMap",
			"services": [ "BlueSpiceWikiFarm.WikiMap", "BlueSpiceWikiFarm._Config" ]
		},
		"rewriteUserPageLink": {
			"class": "BlueSpice\\WikiFarm\\Hook\\SkinTemplateNavigation\\RewriteUserPageLink",
			"services": [ "TitleFactory" ]
		},
		"redirectUserPage": {
			"class": "BlueSpice\\WikiFarm\\Hook\\BeforeInitialize\\RedirectUserPage",
			"services": [ "TitleFactory" ]
		},
		"addGlobalUnifiedTaskOverviewModule": {
			"class": "BlueSpice\\WikiFarm\\Hook\\AddGlobalUTOModule"
		},
		"addGroupPrefix": {
			"class": "BlueSpice\\WikiFarm\\Hook\\FilterImplicitGroupCreation",
			"services": [ "BlueSpiceWikiFarm._Config" ]
		},
		"configureContentTransfer": {
