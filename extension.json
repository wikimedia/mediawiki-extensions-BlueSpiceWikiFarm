{
	"name": "BlueSpiceWikiFarm",
	"version": "6.0.0-alpha",
	"author": [
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://en.wiki.bluespice.com/wiki/Reference:BlueSpiceWikiFarm",
	"descriptionmsg": "wikifarm-desc",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"BlueSpiceFoundation": ">= 5.0.0",
			"OOJSPlus": "*"
		}
	},
	"attributes": {
		"BlueSpiceWikiFarm": {
			"DynamicConfigurationFactories": {},
			"PostInstanceCreationCommandFactories": {
				"runjobs": "BlueSpice\\WikiFarm\\CommandDescription\\RunJobs::factory"
			},
			"PostInstanceDeletionCommandFactories": {},
			"PreInstanceDeletionCommandFactories": {}
		},
		"BlueSpiceFoundation": {
			"PermissionRegistry": {
				"wikifarm-createwiki": {
					"type": "global",
					"roles": [
						"admin"
					]
				},
				"wikifarm-managewiki": {
					"type": "global",
					"roles": [
						"admin"
					]
				},
				"wikifarm-deletewiki": {
					"type": "global",
					"roles": [
						"admin"
					]
				}
			},
			"ConfigDefinitionRegistry": {
				"WikiFarmAccessLevel": "\\BlueSpice\\WikiFarm\\ConfigDefinition\\WikiFarmAccessLevel::getInstance"
			}
		},
		"BlueSpiceExtendedSearch": {
			"PluginRegistry": {
				"global-search": {
					"class": "BlueSpice\\WikiFarm\\ExtendedSearch\\GlobalSearch",
					"services": [ "BlueSpiceWikiFarm._GlobalSearchDataProvider" ]
				}
			}
		},
		"BlueSpiceVisualEditorConnector": {
			"PluginModules": [
				"ext.bluespice.wikiFarm.combinedTitleInput",
				"ext.bluespice.wikiFarm.ve.overrideTemplateDialog"
			]
		},
		"EnhancedUpload": {
			"UploadFormPluginModules": [
				"ext.bluespice.wikiFarm.sharedUpload"
			]
		},
		"BlueSpiceDiscovery": {
			"BreadcrumbDataProviderRegistry": {
				"farmmanagement": {
					"class": "BlueSpice\\WikiFarm\\BreadcrumbDataProvider\\SpecialFarmManagementProvider",
					"services": [ "SpecialPageFactory" ]
				}
			},
			"BreadcrumbRootProviderRegistry": {
				"shared-instances": {
					"class": "BlueSpice\\WikiFarm\\BreadcrumbRootProvider\\SharedInstancesRootNode",
					"services": [ "BlueSpiceWikiFarm._Config", "BlueSpiceWikiFarm.InstanceStore", "SpecialPageFactory" ]
				}
			}
		}
	},
	"DefaultUserOptions": {
		"bs-farm-instances-favorite": ""
	},
	"MessagesDirs": {
		"BlueSpiceWikiFarm": [
			"i18n"
		]
	},
	"SpecialPages": {
		"FarmManagement": {
			"class": "BlueSpice\\WikiFarm\\Special\\FarmManagement",
			"services": [ "LanguageNameUtils", "BlueSpiceWikiFarm._InstanceCountLimiter", "BlueSpiceWikiFarm.InstanceManager" ]
		}
	},
