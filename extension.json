			"services": [ "BlueSpiceWikiFarm._InstancePathGenerator", "BlueSpiceWikiFarm.InstanceStore" ]
		},
		{
			"method": "GET",
			"path": "/bluespice/farm/v1/check_path_validity",
			"class": "\\BlueSpice\\WikiFarm\\Rest\\CheckPathHandler",
			"services": [ "BlueSpiceWikiFarm._InstancePathGenerator" ]
		},
		{
			"path": "/bluespice/farm/v1/combined-title-query-store",
