			"services": [
				"BlueSpiceWikiFarm._Config", "BlueSpiceWikiFarm.AccessControlStore",
				"BlueSpiceWikiFarm.InstanceStore", "BlueSpiceWikiFarm.WikiMap"
			]
		},
		{
			"path": "/bluespice/farm/v1/instance/list",
